# GitHub Configuration
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_ORG=bhapi-inc
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Auth
SECRET_KEY=change-me-in-production

# Database (SQLite default, use postgres for production)
DATABASE_URL=sqlite+aiosqlite:///./bhapi.db

# Redis (optional - cache degrades gracefully without it)
REDIS_URL=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# SMTP (optional - for scheduled report emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: Specific repos to track (comma-separated, leave empty for all)
GITHUB_REPOS=
